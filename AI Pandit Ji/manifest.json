{
  "manifest_version": 3,
  "name": "AI Pandit Ji",
  "description": "Kundli matching with birth details or kundli files, simple match insights, and East and South India views.",
  "version": "1.0.0",
  "host_permissions": [
    "https://api.ocr.space/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://api.open-meteo.com/*",
    "https://nominatim.openstreetmap.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI Pandit Ji",
    "default_popup": "popup.html"
  }
}
